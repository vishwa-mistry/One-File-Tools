{{!
  desert.hbs — A warm, elegant theme with a full set of portfolio sections.
  Renders from profile.json
}}
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{displayName}} — {{title}}</title>
  <meta name="description" content="{{headline}}" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&family=PT+Serif:wght@400;700&family=Source+Code+Pro&display=swap" rel="stylesheet">
  <style>
    @keyframes wave {
      0% { background-position: 0% 0%; }
      50% { background-position: 100% 100%; }
      100% { background-position: 0% 0%; }
    }
    @keyframes pulse-zoom {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.05);
      }
    }
    :root {
      --ink: #3a2d0d; /* text */
      --primary: #a97142; /* accents */
      --primary-light: #f0e5d1; /* highlights */
      --border: #dcd1bb;
      --card-bg: rgba(255, 255, 255, 0.65);
      --white: #ffffff;
      --display: "Cinzel Decorative", serif;
      --sans: "PT Serif", serif;
      --mono: "Source Code Pro", monospace;
    }
    html {
      scroll-behavior: smooth;
      scroll-padding-top: 100px; /* Offset for sticky header */
    }
    body {
      background: linear-gradient(90deg, #f5f2ea, #e8d8b0, #f5f2ea);
      background-size: 200% 200%;
      animation: wave 8s ease-in-out infinite;
      color: var(--ink);
      font-family: var(--sans);
      margin: 0;
      line-height: 1.6;
    }
    .wrap {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    section {
      padding: 4rem 0;
    }
    section:not(.hero) {
      border-top: 1px solid var(--border);
      margin-top: 2rem; /* Adds space above the separator line */
    }
    .sec-title {
      font-size: 2.2rem;
      margin-top: 2rem;
      margin-bottom: 2.5rem;
      text-align: center;
    }
    h1, h2, h3, h4 {
      font-family: var(--display);
      font-weight: 700;
    }

    /* Header */
    header.site {
      padding: 2rem 0;
      position: sticky;
      top: 0;
      background: #000;
      z-index: 10;
      border-bottom: 1px solid var(--primary);
    }
    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .brand {
      font-family: var(--display);
      font-weight: 700;
      font-size: 1.5rem;
      text-decoration: none;
      color: var(--primary-light);
    }
    .nav-links {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      gap: 1.2rem; /* Reduced gap to fit more links */
    }
    .nav-links a {
      text-decoration: none;
      color: var(--primary-light);
      font-weight: 700;
    }

    /* Hero */
    .hero {
      padding: 5rem 0;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      border-top: none;
      position: relative; /* For positioning clusters */
    }

    /* Animated Clusters */
    .cluster-container {
      position: absolute;
      width: 400px;
      height: 400px;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: -1;
      top: 50%;
      transform: translateY(-50%);
    }
    #cluster-left { left: -300px; }
    #cluster-right { right: -300px; }

    .shape {
      position: absolute;
      width: 100px;
      height: 100px;
      top: 150px;
      left: 150px;
      animation-iteration-count: infinite;
      animation-timing-function: ease-in-out;
    }
    .purple-glow { filter: drop-shadow(0 0 20px rgba(181, 23, 158, 0.95)) drop-shadow(0 0 5px rgba(240, 10, 255, 0.5)); }
    .blue-glow { filter: drop-shadow(0 0 20px rgba(0, 191, 255, 0.95)) drop-shadow(0 0 5px rgba(0, 240, 255, 0.5)); }
    .green-glow { filter: drop-shadow(0 0 20px rgba(0, 245, 143, 0.95)) drop-shadow(0 0 5px rgba(150, 255, 180, 0.5)); }

    .hero-photo {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      border: 6px solid var(--ink);
      box-shadow: inset 0 0 0 2px var(--white), 0 0 0 2px var(--white), 0 4px 15px rgba(0,0,0,0.1), 0 0 25px rgba(0, 245, 143, 0.7);
      margin-bottom: 1.5rem;
      animation: pulse-zoom 8s ease-in-out infinite;
    }
    .hero h1 {
      font-size: 3rem;
      margin: 0 0 0.5rem;
      text-shadow: 0 0 12px rgba(255, 255, 255, 0.8);
      animation: pulse-zoom 8s ease-in-out infinite;
    }
    .hero .headline {
      font-size: 1.25rem;
      color: var(--primary);
      margin-bottom: 1.5rem;
    }
    .hero-contact {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .hero-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 1.5rem;
      justify-content: center;
    }
    .hero-links a {
      color: var(--primary);
      font-weight: 600;
      text-decoration: none;
    }
    .location {
      margin-top: 1.5rem;
      font-family: var(--sans);
      opacity: 0.8;
    }
    .btn {
      display: inline-block;
      background: var(--primary);
      color: var(--white);
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.2s;
    }
    .btn:hover {
      background: #8c5a35;
    }

    /* Grids & Cards */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      backdrop-filter: blur(10px);
      transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .card h3 {
      margin: 0 0 0.5rem;
      color: var(--primary);
    }
    .card h4 {
      margin: 0;
      color: var(--primary);
    }
    .card .co {
      font-family: var(--sans);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    .card .tagline {
      font-style: italic;
      opacity: 0.8;
      margin-bottom: 1rem;
    }
    .card .highlights {
      margin: 1rem 0;
      padding-left: 1.2rem;
      font-size: 0.9rem;
      opacity: 0.9;
    }
    .card .tech-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1.5rem 0;
    }
    .card .tech-item {
      background: var(--primary-light);
      color: var(--primary);
      padding: 0.25rem 0.75rem;
      border-radius: 1rem;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .card .project-links {
      margin-top: auto;
      padding-top: 1rem;
      display: flex;
      gap: 1rem;
    }
    .card .project-links a {
      color: var(--primary);
      font-weight: 600;
      text-decoration: none;
    }

    /* Skills */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }
    .skill-list { list-style: none; padding: 0; margin: 0; }
    .skill-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
    }
    .skill-item:last-child { border-bottom: none; }
    .skill-level {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: capitalize;
      padding: 0.1rem 0.5rem;
      border-radius: 4px;
    }
    .skill-level.expert { background-color: #c8e6c9; color: #255d28; }
    .skill-level.advanced { background-color: #bbdefb; color: #0d47a1; }
    .skill-level.intermediate { background-color: #fff9c4; color: #f57f17; }
    .skill-level.beginner { background-color: #ffccbc; color: #bf360c; }

    /* Testimonials */
    .testimonial-card { display: flex; flex-direction: column; }
    .quote {
      font-size: 1.1rem;
      font-style: italic;
      margin: 0 0 1.5rem;
      border-left: 3px solid var(--primary);
      padding-left: 1rem;
      flex-grow: 1;
    }
    .author { font-weight: 600; align-self: flex-end; text-align: right; }

    /* List Sections */
    .list-section { display: flex; flex-direction: column; gap: 1rem; }
    .list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .list-item .meta {
      margin: 0;
      font-family: var(--sans);
      font-size: 0.9rem;
      opacity: 0.8;
      flex-shrink: 0;
    }
    .list-item .links a {
      color: var(--primary);
      font-weight: 600;
      text-decoration: none;
      margin-left: 1rem;
    }
    .interests-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
    }
    .interest-item {
      background: var(--primary-light);
      color: var(--primary);
      padding: 0.5rem 1rem;
      border-radius: 1.5rem;
      font-weight: 600;
    }

    /* Footer */
    footer.site {
      text-align: center;
      padding: 2rem 0;
      margin-top: 3rem;
      border-top: 1px solid var(--border);
      color: var(--ink);
      opacity: 0.8;
    }
    footer.site a {
      color: var(--primary);
      font-weight: 600;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <header class="site">
    <div class="wrap nav">
      <a href="#" class="brand">{{displayName}}</a>
      <ul class="nav-links">
        {{#has experience}}<li><a href="#experience">Experience</a></li>{{/has}}
        {{#has projects}}<li><a href="#projects">Projects</a></li>{{/has}}
        {{#has skills}}<li><a href="#skills">Skills</a></li>{{/has}}
        {{#has testimonials}}<li><a href="#testimonials">Testimonials</a></li>{{/has}}
        {{#has talks}}<li><a href="#talks">Talks</a></li>{{/has}}
        {{#has publications}}<li><a href="#publications">Publications</a></li>{{/has}}
        {{#has certifications}}<li><a href="#certifications">Certs</a></li>{{/has}}
        {{#has awards}}<li><a href="#awards">Awards</a></li>{{/has}}
        {{#has education}}<li><a href="#education">Education</a></li>{{/has}}
        {{#has interests}}<li><a href="#interests">Interests</a></li>{{/has}}
      </ul>
    </div>
  </header>

  <main>
    <section class="hero wrap">
      <div class="cluster-container" id="cluster-left">
        <svg class="shape purple-glow" viewBox="0 0 100 100"><polygon points="50,5 15,50 50,95" fill="#9d4ede" /><polygon points="50,5 85,50 50,95" fill="#c77dff" /><line x1="50" y1="5" x2="50" y2="95" stroke="#ffffff" stroke-width="1.75" stroke-linecap="round" opacity="0.95" /><line x1="15" y1="50" x2="85" y2="50" stroke="#ffffff" stroke-width="0.75" opacity="0.5" /></svg>
        <svg class="shape blue-glow" viewBox="0 0 100 100"><polygon points="10,10 90,10 50,50" fill="#00b4d8" /><polygon points="10,10 10,90 50,50" fill="#00f0ff" /><polygon points="10,90 90,90 50,50" fill="#0077b6" /><polygon points="90,10 90,90 50,50" fill="#90e0ef" /><line x1="10" y1="10" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.8" /><line x1="90" y1="10" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.8" /><line x1="10" y1="90" x2="50" y2="50" stroke="#ffffff" stroke-width="1" opacity="0.5" /><line x1="90" y1="90" x2="50" y2="50" stroke="#ffffff" stroke-width="1" opacity="0.5" /></svg>
        <svg class="shape green-glow" viewBox="0 0 100 100"><polygon points="50,10 10,85 50,60" fill="#52b788" /><polygon points="50,10 90,85 50,60" fill="#74c69d" /><polygon points="10,85 90,85 50,60" fill="#2d6a4f" /><line x1="50" y1="10" x2="50" y2="60" stroke="#ccffdd" stroke-width="2" opacity="0.9" /><line x1="10" y1="85" x2="50" y2="60" stroke="#ccffdd" stroke-width="1" opacity="0.6" /><line x1="90" y1="85" x2="50" y2="60" stroke="#ccffdd" stroke-width="1" opacity="0.6" /></svg>
        <svg class="shape purple-glow" viewBox="0 0 100 100"><polygon points="50,15 15,80 50,55" fill="#7b2cbf" /><polygon points="50,15 85,80 50,55" fill="#b5179e" /><polygon points="15,80 85,80 50,55" fill="#5a189a" /><line x1="50" y1="15" x2="50" y2="55" stroke="#ffffff" stroke-width="1.25" opacity="0.75" /></svg>
        <svg class="shape green-glow" viewBox="0 0 100 100"><polygon points="20,20 80,20 50,50" fill="#2d6a4f" /><polygon points="20,20 20,80 50,50" fill="#40916c" /><polygon points="20,80 80,80 50,50" fill="#1b4332" /><polygon points="80,20 80,80 50,50" fill="#52b788" /><line x1="20" y1="20" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.7" /><line x1="80" y1="20" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.7" /></svg>
      </div>
      <div class="cluster-container" id="cluster-right">
        <svg class="shape purple-glow" viewBox="0 0 100 100"><polygon points="50,5 15,50 50,95" fill="#9d4ede" /><polygon points="50,5 85,50 50,95" fill="#c77dff" /><line x1="50" y1="5" x2="50" y2="95" stroke="#ffffff" stroke-width="1.75" stroke-linecap="round" opacity="0.95" /><line x1="15" y1="50" x2="85" y2="50" stroke="#ffffff" stroke-width="0.75" opacity="0.5" /></svg>
        <svg class="shape blue-glow" viewBox="0 0 100 100"><polygon points="10,10 90,10 50,50" fill="#00b4d8" /><polygon points="10,10 10,90 50,50" fill="#00f0ff" /><polygon points="10,90 90,90 50,50" fill="#0077b6" /><polygon points="90,10 90,90 50,50" fill="#90e0ef" /><line x1="10" y1="10" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.8" /><line x1="90" y1="10" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.8" /><line x1="10" y1="90" x2="50" y2="50" stroke="#ffffff" stroke-width="1" opacity="0.5" /><line x1="90" y1="90" x2="50" y2="50" stroke="#ffffff" stroke-width="1" opacity="0.5" /></svg>
        <svg class="shape green-glow" viewBox="0 0 100 100"><polygon points="50,10 10,85 50,60" fill="#52b788" /><polygon points="50,10 90,85 50,60" fill="#74c69d" /><polygon points="10,85 90,85 50,60" fill="#2d6a4f" /><line x1="50" y1="10" x2="50" y2="60" stroke="#ccffdd" stroke-width="2" opacity="0.9" /><line x1="10" y1="85" x2="50" y2="60" stroke="#ccffdd" stroke-width="1" opacity="0.6" /><line x1="90" y1="85" x2="50" y2="60" stroke="#ccffdd" stroke-width="1" opacity="0.6" /></svg>
        <svg class="shape purple-glow" viewBox="0 0 100 100"><polygon points="50,15 15,80 50,55" fill="#7b2cbf" /><polygon points="50,15 85,80 50,55" fill="#b5179e" /><polygon points="15,80 85,80 50,55" fill="#5a189a" /><line x1="50" y1="15" x2="50" y2="55" stroke="#ffffff" stroke-width="1.25" opacity="0.75" /></svg>
        <svg class="shape green-glow" viewBox="0 0 100 100"><polygon points="20,20 80,20 50,50" fill="#2d6a4f" /><polygon points="20,20 20,80 50,50" fill="#40916c" /><polygon points="20,80 80,80 50,50" fill="#1b4332" /><polygon points="80,20 80,80 50,50" fill="#52b788" /><line x1="20" y1="20" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.7" /><line x1="80" y1="20" x2="50" y2="50" stroke="#ffffff" stroke-width="1.25" opacity="0.7" /></svg>
      </div>
      {{#if photo}}<img src="{{photo}}" alt="{{displayName}}" class="hero-photo">{{/if}}
      <h1>{{displayName}}</h1>
      <p class="headline">{{title}}</p>
      <p>{{bio}}</p>
      <div class="hero-contact">
        {{#if email}}<a href="mailto:{{email}}" class="btn">Get In Touch</a>{{/if}}
        <div class="hero-links">
          {{#each socialLinks}}<a href="{{url}}" target="_blank" rel="noopener">{{label}}</a>{{/each}}
          {{#if website}}<a href="{{website}}" target="_blank" rel="noopener">{{stripProtocol website}}</a>{{/if}}
        </div>
      </div>
      {{#if locationStr}}<p class="location">{{locationStr}}</p>{{/if}}
    </section>

    {{#has experience}}
    <section class="wrap">
      <h2 id="experience" class="sec-title">Work Experience</h2>
      <div class="grid">
        {{#each experience}}
        <div class="card">
          <h3>{{role}}</h3>
          <p class="co">{{company}} | {{fmtDate startDate}} - {{fmtDate endDate}}</p>
          <p>{{description}}</p>
          {{#has highlights}}
          <ul class="highlights">
            {{#each highlights}}<li>{{.}}</li>{{/each}}
          </ul>
          {{/has}}
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    {{#has projects}}
    <section class="wrap">
      <h2 id="projects" class="sec-title">Featured Projects</h2>
      <div class="grid">
        {{#each projects}}
        <div class="card" style="display: flex; flex-direction: column;">
          <h3>{{name}}</h3>
          {{#if tagline}}<p class="tagline">{{tagline}}</p>{{/if}}
          <p>{{description}}</p>
          {{#has highlights}}<ul class="highlights">{{#each highlights}}<li>{{.}}</li>{{/each}}</ul>{{/has}}
          {{#has techStack}}<div class="tech-stack">{{#each techStack}}<span class="tech-item">{{.}}</span>{{/each}}</div>{{/has}}
          <div class="project-links">
            {{#if liveUrl}}<a href="{{liveUrl}}" target="_blank" rel="noopener">Live Demo</a>{{/if}}
            {{#if repoUrl}}<a href="{{repoUrl}}" target="_blank" rel="noopener">View Source</a>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    {{#has skills}}
    <section class="wrap">
      <h2 id="skills" class="sec-title">Skills</h2>
      <div class="skills-grid">
        {{#each skills}}
        <div class="card">
          <h3>{{category}}</h3>
          <ul class="skill-list">
            {{#each items}}
            <li class="skill-item">
              <span>{{name}}</span>
              <span class="skill-level {{lowercase level}}">{{level}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    {{#has testimonials}}
    <section class="wrap">
      <h2 id="testimonials" class="sec-title">Testimonials</h2>
      <div class="grid">
        {{#each testimonials}}
        <div class="card testimonial-card">
          <blockquote class="quote">"{{quote}}"</blockquote>
          <cite class="author">{{author}}{{#if role}}, {{role}}{{/if}}{{#if company}} at {{company}}{{/if}}</cite>
        </div>
        {{/each}}
      </div>
    </section>
    {{/has}}

    <div id="more">
      {{#has talks}}
      <section class="wrap list-section">
        <h2 id="talks" class="sec-title">Talks</h2>
        {{#each talks}}
        <div class="list-item card">
          <div>
            <h4>{{title}}</h4>
            <p class="meta">{{event}} &middot; {{fmtDate date}}</p>
          </div>
          <div class="links">
            {{#if slidesUrl}}<a href="{{slidesUrl}}" target="_blank" rel="noopener">Slides</a>{{/if}}
            {{#if videoUrl}}<a href="{{videoUrl}}" target="_blank" rel="noopener">Video</a>{{/if}}
          </div>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has publications}}
      <section class="wrap list-section">
        <h2 id="publications" class="sec-title">Publications</h2>
        {{#each publications}}
        <div class="list-item card">
          <h4><a href="{{url}}" target="_blank" rel="noopener">{{title}}</a></h4>
          <p class="meta">{{publisher}} &middot; {{fmtDate date}}</p>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has certifications}}
      <section class="wrap list-section">
        <h2 id="certifications" class="sec-title">Certifications</h2>
        {{#each certifications}}
        <div class="list-item card">
          <h4>{{name}}</h4>
          <p class="meta">{{issuer}} &middot; {{fmtDate date}}</p>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has awards}}
      <section class="wrap list-section">
        <h2 id="awards" class="sec-title">Awards</h2>
        {{#each awards}}
        <div class="list-item card">
          <h4>{{title}}</h4>
          <p class="meta">{{issuer}} &middot; {{date}}</p>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has education}}
      <section class="wrap list-section">
        <h2 id="education" class="sec-title">Education</h2>
        {{#each education}}
        <div class="list-item card">
          <div>
            <h4>{{degree}} in {{field}}</h4>
            <p class="meta">{{institution}} &middot; {{startDate}} - {{endDate}}</p>
          </div>
        </div>
        {{/each}}
      </section>
      {{/has}}

      {{#has interests}}
      <section class="wrap">
        <h2 id="interests" class="sec-title">Interests</h2>
        <div class="interests-list">
          {{#each interests}}<span class="interest-item">{{.}}</span>{{/each}}
        </div>
      </section>
      {{/has}}
    </div>
  </main>

  <footer class="site">
    <div class="wrap">
      <p>&copy; {{year}} {{displayName}}. All rights reserved. | Built with <a href="{{toolsUrl}}">One File Tools</a></p>
    </div>
  </footer>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const shapes = document.querySelectorAll('.shape');
      const styleSheet = document.createElement('style');
      document.head.appendChild(styleSheet);

      shapes.forEach((shape, index) => {
        const animName = `randomMove-${index}`;
        
        const randomX = (Math.random() * 160 - 80).toFixed(1);
        const randomY = (Math.random() * 160 - 80).toFixed(1);
        
        const baseScale = (Math.random() * 0.2 + 0.85).toFixed(2);
        
        const randomRotation = Math.floor(Math.random() * 120 - 60);

        const keyframes = `
          @keyframes ${animName} {
            0%, 100% { 
              transform: translate(0px, 0px) scale(${baseScale}) rotate(0deg); 
              opacity: 0.75; 
            }
            50% { 
              transform: translate(${randomX}px, ${randomY}px) scale(${baseScale}) rotate(${randomRotation}deg); 
              opacity: 1; 
            }
          }
        `;
        styleSheet.sheet.insertRule(keyframes, styleSheet.sheet.cssRules.length);

        const duration = (Math.random() * 3 + 5).toFixed(2);
        const delay = (Math.random() * -5).toFixed(2);

        shape.style.animationName = animName;
        shape.style.animationDuration = `${duration}s`;
        shape.style.animationDelay = `${delay}s`;
      });
    });
  </script>
</body>
</html>