<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{displayName}} — Portfolio</title>
    <style>
      /* === Font & Theme Declarations === */
      @import url("https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&family=Inter:wght@300;400;500;600;700&display=swap");

      :root {
        --bg-dark: #07090e;
        --crt-bg: #0a0d14;
        --terminal-green: #00ff66;
        --cyber-cyan: #00f3ff;
        --cyber-pink: #ff007f;
        --amber: #ffb000;
        --text-primary: #e2e8f0;
        --text-secondary: #94a3b8;
        --window-border: #1e293b;
        --window-bg: rgba(10, 15, 26, 0.85);
      }

      /* === Reset === */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* === CRT Screen and Bezel Frame === */
      body {
        background-color: #030406;
        color: var(--text-primary);
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          sans-serif;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow-x: hidden;
      }

      .monitor-frame {
        width: 100%;
        max-width: 1400px;
        min-height: 100vh;
        background-color: var(--bg-dark);
        position: relative;
        border: 14px solid #1e232b;
        border-radius: 20px;
        box-shadow:
          0 0 0 4px #0c0e12,
          inset 0 0 60px rgba(0, 0, 0, 0.95);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      @media (max-width: 1024px) {
        .monitor-frame {
          border: 6px solid #1e232b;
          border-radius: 10px;
        }
      }

      @media (max-width: 640px) {
        .monitor-frame {
          border: none;
          border-radius: 0;
        }
      }

      /* === CRT Overlay Scanlines === */
      .crt-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.3) 50%);
        background-size: 100% 4px;
        z-index: 9999;
        pointer-events: none;
      }

      .crt-vignette {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        box-shadow: inset 0 0 100px rgba(0, 0, 0, 0.85);
        background: radial-gradient(circle, rgba(0, 0, 0, 0) 65%, rgba(0, 0, 0, 0.8) 100%);
        z-index: 9998;
        pointer-events: none;
      }

      .crt-scanline-beam {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(0, 243, 255, 0.05) 10%, rgba(0, 243, 255, 0.08) 11%, rgba(0, 243, 255, 0.05) 12%, rgba(0, 0, 0, 0) 30%);
        z-index: 9996;
        pointer-events: none;
        animation: scanline-anim 8s linear infinite;
      }

      @keyframes scanline-anim {
        0% {
          transform: translateY(-100%);
        }
        100% {
          transform: translateY(100%);
        }
      }

      @keyframes crt-flicker {
        0% {
          opacity: 0.995;
        }
        50% {
          opacity: 0.985;
        }
        100% {
          opacity: 0.995;
        }
      }

      body::after {
        content: " ";
        display: block;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        background: rgba(18, 16, 16, 0.03);
        opacity: 0;
        z-index: 9997;
        pointer-events: none;
        animation: crt-flicker 0.15s infinite;
      }

      /* === Boot Screen (CSS only) === */
      .boot-screen {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #020305;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 30px;
        font-family: "VT323", monospace;
        animation: fade-out-boot 0.6s ease-in forwards;
        animation-delay: 3.8s;
      }

      .boot-content {
        width: 100%;
        max-width: 600px;
      }

      .boot-header {
        color: var(--text-secondary);
        font-size: 1.1rem;
        line-height: 1.4;
        border-bottom: 2px dashed #1e293b;
        padding-bottom: 15px;
        margin-bottom: 15px;
      }

      .boot-lines p {
        opacity: 0;
        font-size: 1.3rem;
        color: var(--terminal-green);
        margin-bottom: 8px;
      }

      .boot-lines p::before {
        content: "► ";
        color: var(--cyber-cyan);
      }

      .boot-lines .line-1 {
        animation: show-line 0.1s forwards;
        animation-delay: 0.4s;
      }
      .boot-lines .line-2 {
        animation: show-line 0.1s forwards;
        animation-delay: 0.9s;
      }
      .boot-lines .line-3 {
        animation: show-line 0.1s forwards;
        animation-delay: 1.4s;
      }
      .boot-lines .line-4 {
        animation: show-line 0.1s forwards;
        animation-delay: 1.9s;
      }
      .boot-lines .line-5 {
        animation: show-line 0.1s forwards;
        animation-delay: 2.4s;
      }
      .boot-lines .line-6 {
        animation: show-line 0.1s forwards;
        animation-delay: 2.9s;
      }

      @keyframes show-line {
        to {
          opacity: 1;
        }
      }

      .boot-progress {
        margin-top: 30px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .boot-progress-label {
        display: flex;
        justify-content: space-between;
        color: var(--text-secondary);
        font-size: 1.1rem;
      }

      .boot-progress-track {
        height: 16px;
        border: 1px solid #334155;
        padding: 2px;
        background: #090d16;
      }

      .boot-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--terminal-green), var(--cyber-cyan));
        width: 0%;
        animation: load-fill 2.8s cubic-bezier(0.1, 0.8, 0.2, 1) forwards;
        animation-delay: 0.5s;
        box-shadow: 0 0 8px rgba(0, 255, 102, 0.5);
      }

      .boot-status::after {
        content: "INITIALIZING...";
        animation: boot-status-text 2.8s step-end forwards;
        animation-delay: 0.5s;
        color: var(--cyber-cyan);
      }

      @keyframes load-fill {
        to {
          width: 100%;
        }
      }

      @keyframes boot-status-text {
        0% {
          content: "MOUNTING DATA...";
          color: var(--amber);
        }
        30% {
          content: "PARSING RESUME...";
          color: var(--cyber-pink);
        }
        70% {
          content: "EMULATING CRT...";
          color: var(--terminal-green);
        }
        100% {
          content: "BOOT SUCCESSFUL";
          color: var(--terminal-green);
        }
      }

      .boot-footer {
        margin-top: 40px;
        text-align: center;
      }

      .skip-btn {
        display: inline-block;
        padding: 8px 18px;
        border: 1px solid var(--text-secondary);
        color: var(--text-secondary);
        border-radius: 4px;
        cursor: pointer;
        font-size: 1.1rem;
        transition: all 0.2s;
      }

      .skip-btn:hover {
        border-color: var(--cyber-cyan);
        color: var(--cyber-cyan);
        box-shadow: 0 0 10px rgba(0, 243, 255, 0.3);
        background: rgba(0, 243, 255, 0.05);
      }

      @keyframes fade-out-boot {
        to {
          opacity: 0;
          visibility: hidden;
          pointer-events: none;
        }
      }

      /* Checkbox Hack to Skip Boot Screen */
      .skip-boot-cb {
        display: none;
      }

      .skip-boot-cb:checked ~ .monitor-frame .boot-screen {
        display: none !important;
        animation: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      /* === Desktop Layout Structure === */
      .desktop-menu-bar {
        height: 36px;
        background: #0f172a;
        border-bottom: 2px solid #334155;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px;
        font-family: "Share Tech Mono", monospace;
        font-size: 0.9rem;
        color: var(--text-primary);
        z-index: 100;
      }

      .menu-left {
        display: flex;
        gap: 16px;
        align-items: center;
      }

      .menu-logo {
        color: var(--cyber-cyan);
        font-weight: bold;
        text-shadow: 0 0 5px rgba(0, 243, 255, 0.5);
      }

      .menu-item {
        cursor: pointer;
        color: var(--text-secondary);
        padding: 2px 6px;
        border-radius: 3px;
        transition: all 0.15s;
      }

      .menu-item:hover {
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.08);
      }

      .menu-right {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--terminal-green);
      }

      .menu-clock {
        background: #020617;
        padding: 2px 8px;
        border-radius: 4px;
        border: 1px solid #1e293b;
        letter-spacing: 0.5px;
      }

      /* Desktop Work Area */
      .desktop-area {
        flex: 1;
        display: flex;
        position: relative;
        padding: 20px;
        background: radial-gradient(circle at center, rgba(15, 23, 42, 0.6) 0%, rgba(3, 7, 18, 0.9) 100%), linear-gradient(rgba(15, 23, 42, 0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(15, 23, 42, 0.15) 1px, transparent 1px);
        background-size:
          100% 100%,
          25px 25px,
          25px 25px;
        min-height: calc(100vh - 36px);
      }

      @media (max-width: 1024px) {
        .desktop-area {
          flex-direction: column;
          padding: 10px;
        }
      }

      /* Desktop Shortcuts Panel */
      .desktop-shortcuts {
        width: 110px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-right: 15px;
        z-index: 50;
        flex-shrink: 0;
      }

      @media (max-width: 1024px) {
        .desktop-shortcuts {
          width: 100%;
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: center;
          padding-right: 0;
          padding-bottom: 15px;
          border-bottom: 1px dashed #1e293b;
          margin-bottom: 15px;
        }
      }

      .desktop-icon {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        cursor: pointer;
        padding: 8px 4px;
        border: 1px solid transparent;
        border-radius: 6px;
        transition: all 0.2s;
        user-select: none;
      }

      .desktop-icon:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
      }

      .icon-visual {
        font-size: 1.8rem;
        margin-bottom: 6px;
        position: relative;
        filter: drop-shadow(0 0 5px rgba(255, 255, 255, 0.1));
      }

      .icon-label {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.78rem;
        color: var(--text-primary);
        word-break: break-all;
        line-height: 1.2;
      }

      .icon-status-dot {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #334155;
        border: 1.5px solid var(--bg-dark);
        transition: all 0.3s;
      }

      /* Desktop Windows Panel */
      .desktop-workspace {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        align-content: start;
        z-index: 10;
      }

      @media (max-width: 1024px) {
        .desktop-workspace {
          grid-template-columns: 1fr;
          gap: 15px;
        }
      }

      /* Window Checkbox Toggle Classes */
      .win-toggle {
        display: none;
      }

      /* Dynamic Desktop Icon Status indicators & Windows Display toggles */
      #win-profile:checked ~ .monitor-frame .icon-profile .icon-status-dot {
        background-color: var(--amber);
        box-shadow: 0 0 8px var(--amber);
      }
      #win-projects:checked ~ .monitor-frame .icon-projects .icon-status-dot {
        background-color: var(--cyber-cyan);
        box-shadow: 0 0 8px var(--cyber-cyan);
      }
      #win-skills:checked ~ .monitor-frame .icon-skills .icon-status-dot {
        background-color: var(--terminal-green);
        box-shadow: 0 0 8px var(--terminal-green);
      }
      #win-experience:checked ~ .monitor-frame .icon-experience .icon-status-dot {
        background-color: var(--cyber-pink);
        box-shadow: 0 0 8px var(--cyber-pink);
      }
      #win-academics:checked ~ .monitor-frame .icon-academics .icon-status-dot {
        background-color: #3b82f6;
        box-shadow: 0 0 8px #3b82f6;
      }
      #win-testimonials:checked ~ .monitor-frame .icon-testimonials .icon-status-dot {
        background-color: #a855f7;
        box-shadow: 0 0 8px #a855f7;
      }
      #win-extra:checked ~ .monitor-frame .icon-extra .icon-status-dot {
        background-color: #f97316;
        box-shadow: 0 0 8px #f97316;
      }

      #win-profile:not(:checked) ~ .monitor-frame .window-profile {
        display: none !important;
      }
      #win-projects:not(:checked) ~ .monitor-frame .window-projects {
        display: none !important;
      }
      #win-skills:not(:checked) ~ .monitor-frame .window-skills {
        display: none !important;
      }
      #win-experience:not(:checked) ~ .monitor-frame .window-experience {
        display: none !important;
      }
      #win-academics:not(:checked) ~ .monitor-frame .window-academics {
        display: none !important;
      }
      #win-testimonials:not(:checked) ~ .monitor-frame .window-testimonials {
        display: none !important;
      }
      #win-extra:not(:checked) ~ .monitor-frame .window-extra {
        display: none !important;
      }

      /* === Generic Window Styling === */
      .window {
        background: var(--window-bg);
        border: 2px solid var(--accent);
        border-radius: 8px;
        box-shadow:
          0 8px 32px 0 rgba(0, 0, 0, 0.6),
          0 0 20px rgba(var(--accent-rgb), 0.15);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition:
          transform 0.2s,
          box-shadow 0.2s;
      }

      .window:hover {
        box-shadow:
          0 12px 40px 0 rgba(0, 0, 0, 0.7),
          0 0 25px rgba(var(--accent-rgb), 0.25);
      }

      .window-header {
        background: linear-gradient(90deg, var(--accent), rgba(var(--accent-rgb), 0.3));
        height: 32px;
        padding: 0 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: "Share Tech Mono", monospace;
        font-weight: 700;
        color: #020617;
        font-size: 0.88rem;
        user-select: none;
      }

      .window-header-title {
        display: flex;
        align-items: center;
        gap: 8px;
        text-transform: uppercase;
      }

      .window-actions {
        display: flex;
        gap: 6px;
      }

      .win-action-btn {
        width: 20px;
        height: 20px;
        border-radius: 3px;
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(0, 0, 0, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: monospace;
        font-size: 0.8rem;
        font-weight: bold;
        cursor: pointer;
        color: #020617;
        transition: all 0.1s;
      }

      .win-action-btn:hover {
        background: rgba(255, 255, 255, 0.4);
      }

      .win-action-btn.win-close:hover {
        background: var(--cyber-pink);
        color: #fff;
      }

      .window-menu {
        height: 26px;
        border-bottom: 1px solid rgba(var(--accent-rgb), 0.2);
        background: rgba(2, 6, 23, 0.4);
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 12px;
        font-family: "Share Tech Mono", monospace;
        font-size: 0.78rem;
        color: var(--text-secondary);
      }

      .window-menu span {
        cursor: pointer;
      }

      .window-menu span:hover {
        color: var(--text-primary);
      }

      .window-body {
        padding: 20px;
        max-height: 480px;
        overflow-y: auto;
        font-size: 0.92rem;
        line-height: 1.6;
        color: var(--text-primary);
      }

      /* Custom Neon Scrollbar for Windows */
      .window-body::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      .window-body::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.2);
      }
      .window-body::-webkit-scrollbar-thumb {
        background: var(--accent);
        border-radius: 3px;
      }

      /* Individual Window Theme Variables */
      .window-profile {
        --accent: var(--amber);
        --accent-rgb: 255, 176, 0;
        grid-column: span 2;
      }

      .window-projects {
        --accent: var(--cyber-cyan);
        --accent-rgb: 0, 243, 255;
        grid-column: span 2;
      }

      .window-skills {
        --accent: var(--terminal-green);
        --accent-rgb: 0, 255, 102;
      }

      .window-experience {
        --accent: var(--cyber-pink);
        --accent-rgb: 255, 0, 127;
      }

      .window-academics {
        --accent: #3b82f6;
        --accent-rgb: 59, 130, 246;
      }

      .window-testimonials {
        --accent: #a855f7;
        --accent-rgb: 168, 85, 247;
      }

      .window-extra {
        --accent: #f97316;
        --accent-rgb: 249, 115, 22;
        grid-column: span 2;
      }

      @media (max-width: 1024px) {
        .window-profile,
        .window-projects,
        .window-skills,
        .window-experience,
        .window-academics,
        .window-testimonials,
        .window-extra {
          grid-column: span 1;
        }
      }

      /* === Component Styles: Profile Window === */
      .profile-layout {
        display: flex;
        gap: 24px;
        align-items: flex-start;
      }

      @media (max-width: 640px) {
        .profile-layout {
          flex-direction: column;
          align-items: center;
        }
      }

      .profile-photo-container {
        position: relative;
        width: 130px;
        height: 130px;
        border-radius: 8px;
        border: 2px solid var(--accent);
        overflow: hidden;
        box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.3);
        flex-shrink: 0;
      }

      .profile-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(0.2) contrast(1.1);
      }

      .profile-photo-container::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.4) 50%);
        background-size: 100% 4px;
        pointer-events: none;
      }

      .profile-info {
        flex: 1;
      }

      .profile-name {
        font-family: "Share Tech Mono", monospace;
        font-size: 2rem;
        color: var(--accent);
        text-shadow: 0 0 8px rgba(var(--accent-rgb), 0.4);
        margin-bottom: 4px;
        font-weight: 700;
      }

      .profile-title {
        font-family: "Share Tech Mono", monospace;
        font-size: 1.1rem;
        color: var(--text-primary);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .profile-title::before {
        content: "[";
        color: var(--accent);
      }

      .profile-title::after {
        content: "]";
        color: var(--accent);
      }

      .profile-bio {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin-bottom: 20px;
      }

      .profile-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
        border-top: 1px dashed rgba(var(--accent-rgb), 0.25);
        padding-top: 15px;
        margin-bottom: 15px;
      }

      .meta-item {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.85rem;
        color: var(--text-secondary);
      }

      .meta-item strong {
        color: var(--text-primary);
      }

      .profile-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .cli-btn {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.82rem;
        padding: 6px 14px;
        background: rgba(var(--accent-rgb), 0.05);
        border: 1px solid var(--accent);
        color: var(--accent);
        border-radius: 4px;
        text-decoration: none;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .cli-btn::before {
        content: ">";
      }

      .cli-btn:hover {
        background: var(--accent);
        color: #000;
        box-shadow: 0 0 10px rgba(var(--accent-rgb), 0.4);
        transform: translateY(-1px);
      }

      /* === Component Styles: Projects Explorer === */
      .projects-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .project-card {
        border: 1px solid rgba(var(--accent-rgb), 0.2);
        border-radius: 6px;
        background: rgba(2, 6, 23, 0.4);
        padding: 16px;
        position: relative;
        transition: all 0.2s;
      }

      .project-card:hover {
        border-color: var(--accent);
        box-shadow: inset 0 0 10px rgba(var(--accent-rgb), 0.08);
        transform: translateX(4px);
      }

      .project-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 8px;
      }

      .project-card-title {
        font-family: "Share Tech Mono", monospace;
        font-size: 1.15rem;
        color: var(--accent);
        font-weight: bold;
      }

      .project-tagline {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.82rem;
        color: var(--text-secondary);
        margin-bottom: 12px;
        display: inline-block;
        padding: 2px 8px;
        background: rgba(var(--accent-rgb), 0.1);
        border-radius: 4px;
      }

      .project-desc {
        color: var(--text-primary);
        font-size: 0.9rem;
        margin-bottom: 14px;
      }

      .tech-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 14px;
      }

      .tech-chip {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.72rem;
        padding: 2px 8px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        color: var(--text-secondary);
      }

      .project-highlights {
        list-style: none;
        margin-bottom: 14px;
      }

      .project-highlights li {
        font-size: 0.85rem;
        color: var(--text-secondary);
        padding-left: 18px;
        position: relative;
        margin-bottom: 4px;
      }

      .project-highlights li::before {
        content: "◈";
        position: absolute;
        left: 0;
        color: var(--accent);
        font-size: 0.75rem;
      }

      .project-links {
        display: flex;
        gap: 10px;
      }

      /* === Component Styles: Skill Monitor === */
      .skills-stack {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .skill-group {
        border-bottom: 1px dashed rgba(var(--accent-rgb), 0.2);
        padding-bottom: 15px;
      }

      .skill-group:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .skill-group-title {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.95rem;
        color: var(--accent);
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .skill-group-title::before {
        content: "►";
      }

      .skill-items-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .skill-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 15px;
      }

      .skill-name {
        font-size: 0.86rem;
        color: var(--text-primary);
      }

      .skill-readout {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 140px;
        flex-shrink: 0;
      }

      .skill-bar-track {
        flex: 1;
        height: 8px;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(var(--accent-rgb), 0.3);
        padding: 1px;
        border-radius: 2px;
      }

      .skill-bar-fill {
        height: 100%;
        background: var(--accent);
        border-radius: 1px;
        box-shadow: 0 0 5px rgba(var(--accent-rgb), 0.5);
      }

      .skill-level-label {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.72rem;
        color: var(--text-secondary);
        width: 50px;
        text-align: right;
        text-transform: uppercase;
      }

      /* === Component Styles: Experience Log === */
      .timeline {
        position: relative;
        padding-left: 20px;
      }

      .timeline::before {
        content: "";
        position: absolute;
        left: 4px;
        top: 5px;
        bottom: 5px;
        width: 2px;
        background: rgba(var(--accent-rgb), 0.2);
      }

      .timeline-item {
        position: relative;
        margin-bottom: 24px;
      }

      .timeline-item:last-child {
        margin-bottom: 0;
      }

      .timeline-marker {
        position: absolute;
        left: -22px;
        top: 5px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: var(--bg-dark);
        border: 2px solid var(--accent);
        box-shadow: 0 0 8px var(--accent);
        z-index: 2;
      }

      .timeline-header {
        margin-bottom: 6px;
      }

      .timeline-role {
        font-family: "Share Tech Mono", monospace;
        font-size: 1.05rem;
        color: var(--accent);
        font-weight: bold;
      }

      .timeline-meta {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-bottom: 6px;
      }

      .timeline-desc {
        color: var(--text-primary);
        font-size: 0.88rem;
      }

      /* === Component Styles: Academics Window === */
      .academics-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .academic-section {
        border-bottom: 1px dashed rgba(var(--accent-rgb), 0.2);
        padding-bottom: 15px;
      }

      .academic-section:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .academic-title {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.95rem;
        color: var(--accent);
        margin-bottom: 10px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .academic-title::before {
        content: "■";
        font-size: 0.7rem;
      }

      .academic-card {
        background: rgba(2, 6, 23, 0.3);
        border: 1px solid rgba(var(--accent-rgb), 0.15);
        padding: 12px;
        border-radius: 4px;
        margin-bottom: 8px;
      }

      .academic-card:last-child {
        margin-bottom: 0;
      }

      .academic-card h4 {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.92rem;
        color: var(--text-primary);
        margin-bottom: 4px;
      }

      .academic-card .meta {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.78rem;
        color: var(--text-secondary);
      }

      .lang-tag-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .lang-tag {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.8rem;
        padding: 4px 10px;
        border: 1px solid rgba(var(--accent-rgb), 0.3);
        background: rgba(var(--accent-rgb), 0.05);
        color: var(--text-primary);
        border-radius: 4px;
      }

      /* === Component Styles: Testimonials Window === */
      .testimonials-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
      }

      .testimonial-bubble {
        background: rgba(2, 6, 23, 0.4);
        border: 1px solid rgba(var(--accent-rgb), 0.2);
        border-radius: 6px;
        padding: 14px;
        position: relative;
      }

      .testimonial-bubble::after {
        content: "";
        position: absolute;
        bottom: -1px;
        right: 30px;
        transform: rotate(45deg);
      }

      .testimonial-text {
        font-size: 0.88rem;
        font-style: italic;
        color: var(--text-primary);
        margin-bottom: 10px;
        line-height: 1.5;
      }

      .testimonial-author {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.78rem;
        color: var(--accent);
        text-align: right;
      }

      .testimonial-author strong {
        color: var(--text-primary);
      }

      /* === Component Styles: Extra archives Window === */
      .archives-layout {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      @media (max-width: 768px) {
        .archives-layout {
          grid-template-columns: 1fr;
        }
      }

      .archive-col {
        display: flex;
        flex-direction: column;
        gap: 15px;
      }

      .interest-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .interest-chip {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.8rem;
        padding: 4px 10px;
        border: 1px solid rgba(var(--accent-rgb), 0.25);
        border-radius: 4px;
        background: rgba(var(--accent-rgb), 0.03);
        color: var(--text-secondary);
        transition: all 0.2s;
      }

      .interest-chip:hover {
        border-color: var(--accent);
        color: var(--text-primary);
        box-shadow: 0 0 5px rgba(var(--accent-rgb), 0.3);
      }

      /* === Footer Styling === */
      .desktop-footer {
        height: 32px;
        background: #090d16;
        border-top: 1px solid #1e293b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Share Tech Mono", monospace;
        font-size: 0.76rem;
        color: var(--text-secondary);
        z-index: 50;
      }

      .desktop-footer a {
        color: var(--cyber-cyan);
        text-decoration: none;
      }

      .desktop-footer a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>

    <!-- Hidden Checkbox Hack elements to toggle boot screen and show/hide windows -->
    <input type="checkbox" id="skip-boot-cb" class="skip-boot-cb" />

    {{#has personal}}
      <input type="checkbox" id="win-profile" checked class="win-toggle" />
    {{/has}}

    {{#has projects}}
      <input type="checkbox" id="win-projects" checked class="win-toggle" />
    {{/has}}

    {{#has skills}}
      <input type="checkbox" id="win-skills" checked class="win-toggle" />
    {{/has}}

    {{#has experience}}
      <input type="checkbox" id="win-experience" checked class="win-toggle" />
    {{/has}}

    <input type="checkbox" id="win-academics" checked class="win-toggle" />

    {{#has testimonials}}
      <input type="checkbox" id="win-testimonials" checked class="win-toggle" />
    {{/has}}

    <input type="checkbox" id="win-extra" checked class="win-toggle" />

    <!-- Monitor Framing bezel -->
    <div class="monitor-frame">

      <!-- CRT Visual Overlays -->
      <div class="crt-overlay"></div>
      <div class="crt-vignette"></div>
      <div class="crt-scanline-beam"></div>

      <!-- BIOS Boot Screen Overlay -->
      <div class="boot-screen">
        <div class="boot-content">
          <div class="boot-header">
            <div>ANTIGRAVITY BIOS v1.0.4 - RELEASE: 2026-07-01</div>
            <div>CPU: GEMINI FLASH 3.5 @ CORE SPEED 4.20GHz</div>
            <div>RAM: 64KB OK</div>
            <div>SYSTEM INIT...</div>
          </div>
          <div class="boot-lines">
            <p class="line-1">Loading system configurations...</p>
            <p class="line-2">Establishing secure link...</p>
            <p class="line-3">Initializing CRT display modules...</p>
            <p class="line-4">Reading data/profile.json...</p>
            <p class="line-5">Compiling Handlebars template variables...</p>
            <p class="line-6">SUCCESS: Personal profile loaded.</p>
          </div>
          <div class="boot-progress">
            <div class="boot-progress-label">
              <span>STATUS: <span class="boot-status"></span></span>
              <span>SYSTEM BOOTING</span>
            </div>
            <div class="boot-progress-track">
              <div class="boot-progress-fill"></div>
            </div>
          </div>
          <div class="boot-footer">
            <label for="skip-boot-cb" class="skip-btn">[ PRESS TO SKIP BOOT ]</label>
          </div>
        </div>
      </div>

      <!-- Desktop Menu Bar -->
      <header class="desktop-menu-bar">
        <div class="menu-left">
          <span class="menu-logo">AG_OS v1.0.0</span>
          <span class="menu-item">System</span>
          <span class="menu-item">Programs</span>
          <span class="menu-item">Help</span>
        </div>
        <div class="menu-right">
          <span>TIME:</span>
          <span id="system-time" class="menu-clock">13:50:57</span>
        </div>
      </header>

      <!-- Desktop Area containing icons & windows -->
      <main class="desktop-area">

        <!-- Desktop Sidebar with Shortcuts -->
        <aside class="desktop-shortcuts">
          {{#has personal}}
            <label for="win-profile" class="desktop-icon icon-profile">
              <div class="icon-visual">👤<div class="icon-status-dot"></div></div>
              <div class="icon-label">profile.txt</div>
            </label>
          {{/has}}

          {{#has projects}}
            <label for="win-projects" class="desktop-icon icon-projects">
              <div class="icon-visual">📁<div class="icon-status-dot"></div></div>
              <div class="icon-label">projects.dir</div>
            </label>
          {{/has}}

          {{#has skills}}
            <label for="win-skills" class="desktop-icon icon-skills">
              <div class="icon-visual">⚡<div class="icon-status-dot"></div></div>
              <div class="icon-label">skills.cfg</div>
            </label>
          {{/has}}

          {{#has experience}}
            <label for="win-experience" class="desktop-icon icon-experience">
              <div class="icon-visual">📜<div class="icon-status-dot"></div></div>
              <div class="icon-label">history.log</div>
            </label>
          {{/has}}

          <label for="win-academics" class="desktop-icon icon-academics">
            <div class="icon-visual">🎓<div class="icon-status-dot"></div></div>
            <div class="icon-label">academic.bin</div>
          </label>

          {{#has testimonials}}
            <label for="win-testimonials" class="desktop-icon icon-testimonials">
              <div class="icon-visual">💬<div class="icon-status-dot"></div></div>
              <div class="icon-label">comms.txt</div>
            </label>
          {{/has}}

          <label for="win-extra" class="desktop-icon icon-extra">
            <div class="icon-visual">🗄️<div class="icon-status-dot"></div></div>
            <div class="icon-label">archives.sys</div>
          </label>
        </aside>

        <!-- Desktop Workspace Grid containing the active windows -->
        <div class="desktop-workspace">

          <!-- 1. PROFILE WINDOW -->
          {{#has personal}}
            <section class="window window-profile">
              <div class="window-header">
                <div class="window-header-title">👤 Profile - profile.txt</div>
                <div class="window-actions">
                  <label for="win-profile" class="win-action-btn" title="Minimize">_</label>
                  <label for="win-profile" class="win-action-btn" title="Maximize">□</label>
                  <label for="win-profile" class="win-action-btn win-close" title="Close">×</label>
                </div>
              </div>
              <div class="window-menu">
                <span>File</span>
                <span>Edit</span>
                <span>View</span>
                <span>Help</span>
              </div>
              <div class="window-body">
                <div class="profile-layout">
                  {{#if photo}}
                    <div class="profile-photo-container">
                      <img class="profile-photo" src="{{photo}}" alt="{{displayName}}" />
                    </div>
                  {{/if}}
                  <div class="profile-info">
                    <h1 class="profile-name">{{displayName}}</h1>
                    {{#if title}}
                      <div class="profile-title">{{title}}</div>
                    {{/if}}
                    {{#if bio}}
                      <p class="profile-bio">{{bio}}</p>
                    {{/if}}

                    <div class="profile-meta-grid">
                      {{#if locationStr}}
                        <div class="meta-item">LOCATION: <strong>{{locationStr}}</strong></div>
                      {{/if}}
                      {{#if email}}
                        <div class="meta-item">EMAIL: <strong>{{email}}</strong></div>
                      {{/if}}
                      {{#if phone}}
                        <div class="meta-item">PHONE: <strong>{{phone}}</strong></div>
                      {{/if}}
                      {{#if website}}
                        <div class="meta-item">WEB: <strong><a href="{{website}}" style="color: var(--accent);" target="_blank" rel="noopener noreferrer">{{stripProtocol website}}</a></strong></div>
                      {{/if}}
                    </div>

                    <div class="profile-links">
                      {{#if email}}
                        <a href="mailto:{{email}}" class="cli-btn">Email</a>
                      {{/if}}
                      {{#if website}}
                        <a href="{{website}}" class="cli-btn" target="_blank" rel="noopener noreferrer">Website</a>
                      {{/if}}
                      {{#socialLinks}}
                        <a href="{{url}}" class="cli-btn" target="_blank" rel="noopener noreferrer">{{label}}</a>
                      {{/socialLinks}}
                    </div>
                  </div>
                </div>
              </div>
            </section>
          {{/has}}

          <!-- 2. PROJECTS WINDOW -->
          {{#has projects}}
            <section class="window window-projects">
              <div class="window-header">
                <div class="window-header-title">📁 Project Explorer - projects.dir</div>
                <div class="window-actions">
                  <label for="win-projects" class="win-action-btn" title="Minimize">_</label>
                  <label for="win-projects" class="win-action-btn" title="Maximize">□</label>
                  <label for="win-projects" class="win-action-btn win-close" title="Close">×</label>
                </div>
              </div>
              <div class="window-menu">
                <span>File</span>
                <span>View</span>
                <span>Tools</span>
                <span>Help</span>
              </div>
              <div class="window-body">
                <div class="projects-container">
                  {{#projects}}
                    <div class="project-card">
                      <div class="project-card-header">
                        <div class="project-card-title">{{name}}</div>
                        {{#if year}}
                          <div style="font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: var(--accent);">[{{year}}]</div>
                        {{/if}}
                      </div>
                      {{#if tagline}}
                        <div class="project-tagline">{{tagline}}</div>
                      {{/if}}
                      {{#if description}}
                        <p class="project-desc">{{description}}</p>
                      {{/if}}

                      {{#has techStack}}
                        <div class="tech-chips">
                          {{#techStack}}
                            <span class="tech-chip">{{.}}</span>
                          {{/techStack}}
                        </div>
                      {{/has}}

                      {{#has highlights}}
                        <ul class="project-highlights">
                          {{#highlights}}
                            <li>{{.}}</li>
                          {{/highlights}}
                        </ul>
                      {{/has}}

                      <div class="project-links">
                        {{#if liveUrl}}
                          <a href="{{liveUrl}}" class="cli-btn" target="_blank" rel="noopener noreferrer">Live Demo</a>
                        {{/if}}
                        {{#if repoUrl}}
                          <a href="{{repoUrl}}" class="cli-btn" target="_blank" rel="noopener noreferrer">Source Code</a>
                        {{/if}}
                      </div>
                    </div>
                  {{/projects}}
                </div>
              </div>
            </section>
          {{/has}}

          <!-- 3. SKILLS WINDOW -->
          {{#has skills}}
            <section class="window window-skills">
              <div class="window-header">
                <div class="window-header-title">⚡ Skill Telemetry - skills.cfg</div>
                <div class="window-actions">
                  <label for="win-skills" class="win-action-btn" title="Minimize">_</label>
                  <label for="win-skills" class="win-action-btn" title="Maximize">□</label>
                  <label for="win-skills" class="win-action-btn win-close" title="Close">×</label>
                </div>
              </div>
              <div class="window-menu">
                <span>Diagnostics</span>
                <span>Help</span>
              </div>
              <div class="window-body">
                <div class="skills-stack">
                  {{#skills}}
                    <div class="skill-group">
                      <div class="skill-group-title">{{category}}</div>
                      <div class="skill-items-list">
                        {{#items}}
                          <div class="skill-item">
                            <span class="skill-name">{{name}}</span>
                            <div class="skill-readout">
                              <div class="skill-bar-track">
                                <div class="skill-bar-fill" style="width: {{levelPercent level}}%;"></div>
                              </div>
                              <span class="skill-level-label">{{level}}</span>
                            </div>
                          </div>
                        {{/items}}
                      </div>
                    </div>
                  {{/skills}}
                </div>
              </div>
            </section>
          {{/has}}

          <!-- 4. EXPERIENCE TIMELINE WINDOW -->
          {{#has experience}}
            <section class="window window-experience">
              <div class="window-header">
                <div class="window-header-title">📜 Chronological Logs - history.log</div>
                <div class="window-actions">
                  <label for="win-experience" class="win-action-btn" title="Minimize">_</label>
                  <label for="win-experience" class="win-action-btn" title="Maximize">□</label>
                  <label for="win-experience" class="win-action-btn win-close" title="Close">×</label>
                </div>
              </div>
              <div class="window-menu">
                <span>View</span>
                <span>Options</span>
                <span>Help</span>
              </div>
              <div class="window-body">
                <div class="timeline">
                  {{#experience}}
                    <div class="timeline-item">
                      <div class="timeline-marker"></div>
                      <div class="timeline-header">
                        <div class="timeline-role">{{role}}</div>
                        <div class="timeline-meta">{{company}} &middot; {{fmtDate startDate}} — {{fmtDate endDate}}{{#if location}} &middot; {{location}}{{/if}}</div>
                      </div>
                      {{#if description}}
                        <p class="timeline-desc">{{description}}</p>
                      {{/if}}
                    </div>
                  {{/experience}}
                </div>
              </div>
            </section>
          {{/has}}

          <!-- 5. ACADEMIC RECORDS WINDOW (Education, Certifications, Awards, Languages) -->
          <section class="window window-academics">
            <div class="window-header">
              <div class="window-header-title">🎓 Academic Records - academic.bin</div>
              <div class="window-actions">
                <label for="win-academics" class="win-action-btn" title="Minimize">_</label>
                <label for="win-academics" class="win-action-btn" title="Maximize">□</label>
                <label for="win-academics" class="win-action-btn win-close" title="Close">×</label>
              </div>
            </div>
            <div class="window-menu">
              <span>Filter</span>
              <span>Help</span>
            </div>
            <div class="window-body">
              <div class="academics-container">
                <!-- Education sub-section -->
                {{#has education}}
                  <div class="academic-section">
                    <div class="academic-title">Education</div>
                    {{#education}}
                      <div class="academic-card">
                        <h4>{{degree}}{{#if field}} in {{field}}{{/if}}</h4>
                        <div class="meta">{{institution}}</div>
                        <div class="meta" style="color: var(--text-secondary);">{{fmtDate startDate}} — {{fmtDate endDate}}{{#if gpa}} &middot; GPA: {{gpa}}{{/if}}</div>
                      </div>
                    {{/education}}
                  </div>
                {{/has}}

                <!-- Certifications sub-section -->
                {{#has certifications}}
                  <div class="academic-section">
                    <div class="academic-title">Certifications</div>
                    {{#certifications}}
                      <div class="academic-card">
                        <h4>{{name}}</h4>
                        <div class="meta">{{issuer}} &middot; {{fmtDate date}}</div>
                      </div>
                    {{/certifications}}
                  </div>
                {{/has}}

                <!-- Awards sub-section -->
                {{#has awards}}
                  <div class="academic-section">
                    <div class="academic-title">Awards</div>
                    {{#awards}}
                      <div class="academic-card">
                        <h4>{{title}}</h4>
                        <div class="meta">{{issuer}} &middot; {{fmtDate date}}</div>
                        {{#if description}}
                          <p class="meta" style="color: var(--text-secondary); margin-top: 4px;">{{description}}</p>
                        {{/if}}
                      </div>
                    {{/awards}}
                  </div>
                {{/has}}

                <!-- Languages sub-section -->
                {{#has languages}}
                  <div class="academic-section">
                    <div class="academic-title">Languages</div>
                    <div class="lang-tag-grid">
                      {{#languages}}
                        <span class="lang-tag">{{language}} ({{proficiency}})</span>
                      {{/languages}}
                    </div>
                  </div>
                {{/has}}
              </div>
            </div>
          </section>

          <!-- 6. TESTIMONIALS WINDOW -->
          {{#has testimonials}}
            <section class="window window-testimonials">
              <div class="window-header">
                <div class="window-header-title">💬 Feedback Portal - comms.txt</div>
                <div class="window-actions">
                  <label for="win-testimonials" class="win-action-btn" title="Minimize">_</label>
                  <label for="win-testimonials" class="win-action-btn" title="Maximize">□</label>
                  <label for="win-testimonials" class="win-action-btn win-close" title="Close">×</label>
                </div>
              </div>
              <div class="window-menu">
                <span>Channels</span>
                <span>Help</span>
              </div>
              <div class="window-body">
                <div class="testimonials-container">
                  {{#testimonials}}
                    <div class="testimonial-bubble">
                      <p class="testimonial-text">"{{quote}}"</p>
                      <div class="testimonial-author">
                        &mdash;
                        <strong>{{author}}</strong>{{#if role}}, {{role}}{{/if}}{{#if company}} at {{company}}{{/if}}
                      </div>
                    </div>
                  {{/testimonials}}
                </div>
              </div>
            </section>
          {{/has}}

          <!-- 7. EXTRA ARCHIVES WINDOW (Talks, Publications, Volunteer, Interests) -->
          <section class="window window-extra">
            <div class="window-header">
              <div class="window-header-title">🗄️ System Archives - archives.sys</div>
              <div class="window-actions">
                <label for="win-extra" class="win-action-btn" title="Minimize">_</label>
                <label for="win-extra" class="win-action-btn" title="Maximize">□</label>
                <label for="win-extra" class="win-action-btn win-close" title="Close">×</label>
              </div>
            </div>
            <div class="window-menu">
              <span>Category</span>
              <span>View</span>
              <span>Help</span>
            </div>
            <div class="window-body">
              <div class="archives-layout">
                <div class="archive-col">
                  <!-- Talks sub-section -->
                  {{#has talks}}
                    <div class="academic-section" style="border-bottom: none;">
                      <div class="academic-title">Public Speaking</div>
                      {{#talks}}
                        <div class="academic-card">
                          <h4>{{title}}</h4>
                          <div class="meta">{{event}} &middot; {{fmtDate date}}{{#if location}} &middot; {{location}}{{/if}}</div>
                          <div class="project-links" style="margin-top: 8px;">
                            {{#if slidesUrl}}
                              <a href="{{slidesUrl}}" class="cli-btn" target="_blank" rel="noopener noreferrer">Slides</a>
                            {{/if}}
                            {{#if videoUrl}}
                              <a href="{{videoUrl}}" class="cli-btn" target="_blank" rel="noopener noreferrer">Video</a>
                            {{/if}}
                          </div>
                        </div>
                      {{/talks}}
                    </div>
                  {{/has}}

                  <!-- Publications sub-section -->
                  {{#has publications}}
                    <div class="academic-section" style="border-bottom: none;">
                      <div class="academic-title">Publications</div>
                      {{#publications}}
                        <div class="academic-card">
                          {{#if url}}
                            <h4><a href="{{url}}" style="color: var(--accent); text-decoration: none;" target="_blank" rel="noopener noreferrer">{{title}}</a></h4>
                          {{else}}
                            <h4>{{title}}</h4>
                          {{/if}}
                          <div class="meta">{{publisher}} &middot; {{fmtDate date}}</div>
                        </div>
                      {{/publications}}
                    </div>
                  {{/has}}
                </div>

                <div class="archive-col">
                  <!-- Volunteer sub-section -->
                  {{#has volunteer}}
                    <div class="academic-section" style="border-bottom: none;">
                      <div class="academic-title">Volunteer Work</div>
                      {{#volunteer}}
                        <div class="academic-card">
                          <h4>{{role}}</h4>
                          <div class="meta">{{organization}}</div>
                          <div class="meta" style="color: var(--text-secondary); margin-bottom: 4px;">{{fmtDate startDate}} — {{fmtDate endDate}}</div>
                          {{#if description}}
                            <p class="meta" style="color: var(--text-primary);">{{description}}</p>
                          {{/if}}
                        </div>
                      {{/volunteer}}
                    </div>
                  {{/has}}

                  <!-- Interests sub-section -->
                  {{#has interests}}
                    <div class="academic-section" style="border-bottom: none;">
                      <div class="academic-title">Interests</div>
                      <div class="interest-chips">
                        {{#interests}}
                          <span class="interest-chip">{{.}}</span>
                        {{/interests}}
                      </div>
                    </div>
                  {{/has}}
                </div>
              </div>
            </div>
          </section>

        </div>
      </main>

      <!-- Desktop Footer/Statusbar -->
      <footer class="desktop-footer">
        <p>System Powered by <a href="{{toolsUrl}}" target="_blank" rel="noopener noreferrer">One File Tools</a> &middot; &copy; {{year}}</p>
      </footer>

    </div>

    <!-- Realtime clock helper -->
    <script>
      (function() { function updateTime() { const timeEl = document.getElementById('system-time'); if (!timeEl) return; const now = new Date(); const hrs = String(now.getHours()).padStart(2, '0'); const mins = String(now.getMinutes()).padStart(2, '0'); const secs = String(now.getSeconds()).padStart(2, '0'); timeEl.textContent = `${hrs}:${mins}:${secs}`; } setInterval(updateTime, 1000); updateTime(); })();
    </script>
  </body>
</html>